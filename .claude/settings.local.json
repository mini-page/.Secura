{
  "permissions": {
    "allow": [
      "Bash(flutter *)",
      "Bash(dart *)",
      "Bash(sed -i '1d; 16d' lib/app_shell.dart)",
      "Bash(sed -i '8d' lib/core/services/file_vault_service.dart)",
      "Bash(sed -i '6d' lib/features/vault/import_screen.dart)",
      "Skill(update-config)"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "env": {
    "FLUTTER_SUPPRESS_ANALYTICS": "true"
  },
  "respectGitignore": true,
  "autoCompactEnabled": true,
  "cleanupPeriodDays": 60
}
